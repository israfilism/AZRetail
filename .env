AIRFLOW_IMAGE_NAME=azretail_airflow_image:2.10.5
AIRFLOW_PROJ_DIR=./airflow
AIRFLOW_UID=50000

AIRFLOW__CORE__EXECUTOR=LocalExecutor
AIRFLOW__DATABASE__SQL_ALCHEMY_CONN=postgresql+psycopg2://airflow:airflow@postgres/airflow
AIRFLOW__CORE__SQL_ALCHEMY_CONN=postgresql+psycopg2://airflow:airflow@postgres/airflow
AIRFLOW__CORE__FERNET_KEY=7T9_vV7Z6E7z614_M3k7U-89ABCDEF0123456789ABC=
AIRFLOW__CORE__DAGS_ARE_PAUSED_AT_CREATION=true
AIRFLOW__CORE__LOAD_EXAMPLES=false
AIRFLOW__CORE__DAGS_FOLDER=/opt/airflow/dags/
AIRFLOW__CORE__TEST_CONNECTION=Enabled
AIRFLOW__SCHEDULER__ENABLE_HEALTH_CHECK=true
AIRFLOW__SCHEDULER__DAG_DIR_LIST_INTERVAL=5
AIRFLOW__API__AUTH_BACKENDS=airflow.api.auth.backend.basic_auth,airflow.api.auth.backend.session
AIRFLOW__LOGGING__LOGGING_LEVEL=INFO

AIRFLOW_WWM_USER_CREATE=true
AIRFLOW_WWM_USER_USERNAME=airflow
AIRFLOW_WWM_USER_PASSWORD=airflow

POSTGRES_USER=airflow
POSTGRES_PASSWORD=airflow
POSTGRES_DB=airflow